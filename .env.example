# ─── Ministros Voice Agent — Environment Variables ───
# Copy to .env and fill in your values

# AI Service API Keys (REQUIRED)
GROQ_API_KEY=your_groq_key
SARVAM_API_KEY=your_sarvam_key
CEREBRAS_API_KEY=your_cerebras_key

# Server Configuration
HOST=0.0.0.0
PORT=8805

# CORS Origins (comma-separated, use * for development)
# For production, set to your frontend domain:
# CORS_ORIGINS=https://your-frontend.azurestaticapps.net
CORS_ORIGINS=*

# ─── Security ────────────────────────────────────────
# WebSocket origin validation (comma-separated)
# Set to your frontend URL in production
ALLOWED_WS_ORIGINS=*

# Max concurrent WebSocket sessions per IP
MAX_CONCURRENT_SESSIONS=10

# Session timeout in seconds (default: 600 = 10 minutes)
SESSION_TIMEOUT_SECS=600

# JWT auth (set to true + provide secret for production)
REQUIRE_AUTH=false
JWT_SECRET=change-this-in-production
